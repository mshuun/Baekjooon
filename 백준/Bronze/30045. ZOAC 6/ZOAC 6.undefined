#include <iostream>
#include <string>

using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int N, emo = 0;
    cin >> N;

    while (N--) {
        string S;
        cin >> S;
        if (S.contains("01") || S.contains("OI"))
            emo++;
    }

    cout << emo << "\n";

    return 0;
}